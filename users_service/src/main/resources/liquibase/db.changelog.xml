<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <property name="type.boolean" value="bit(1)"/>

    <changeSet id="RENAME_COLUMN_NAME" author="e.zinkovskaya">
        <renameColumn
                oldColumnName="user_owner"
                columnDataType="${type.boolean}"
                newColumnName="user_admin"
                tableName="venue_curator"/>
    </changeSet>

    <changeSet id="MOVE_VENUE_STATUS_TO_VENUE_ADDRESS" author="e.zinkovskaya">
        <addColumn tableName="venue_address">
            <column name="status" type="VARCHAR(32)"/>
        </addColumn>
        <sql>
            <![CDATA[
            UPDATE venue_address va
            INNER JOIN venue v ON v.id = va.venue_id
            SET va.status = v.status
            ]]>
        </sql>
        <addNotNullConstraint
                tableName="venue_address"
                columnName="status"
                columnDataType="VARCHAR(32)"
                defaultNullValue="PENDING"/>
        <dropColumn tableName="venue" columnName="status"/>
    </changeSet>

</databaseChangeLog>
