<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="users-fk-venue-address-venue-id" author="space">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="venue_address"/>
                <tableExists tableName="venue"/>
                <not>
                    <foreignKeyConstraintExists foreignKeyTableName="venue_address"
                                                foreignKeyName="fk_venue_address_venue"/>
                </not>
            </and>
        </preConditions>
        <addForeignKeyConstraint baseTableName="venue_address" baseColumnNames="venue_id"
                                 constraintName="fk_venue_address_venue"
                                 referencedTableName="venue" referencedColumnNames="id"/>
    </changeSet>

