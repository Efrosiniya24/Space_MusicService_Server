<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="venue-documents-add-venue-address-id" author="space">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="venue_documents" columnName="venue_address_id"/>
            </not>
        </preConditions>
        <addColumn tableName="venue_documents">
            <column name="venue_address_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
