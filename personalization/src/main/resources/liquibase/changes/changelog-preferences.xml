<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="preferences-001-preference" author="personalization">
        <createTable tableName="preference">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT"/>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp"/>
        </createTable>
    </changeSet>

    <changeSet id="preferences-002-preference-address" author="personalization">
        <createTable tableName="preference_address">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="address_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="preference_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex indexName="idx_preference_address_preference_id" tableName="preference_address">
            <column name="preference_id"/>
        </createIndex>
        <addForeignKeyConstraint baseTableName="preference_address"
                                 baseColumnNames="preference_id"
                                 constraintName="fk_preference_address_preference"
                                 referencedTableName="preference"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="preferences-003-preference-genre" author="personalization">
        <createTable tableName="preference_genre">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="genre_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="preference_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex indexName="idx_preference_genre_preference_id" tableName="preference_genre">
            <column name="preference_id"/>
        </createIndex>
        <addForeignKeyConstraint baseTableName="preference_genre"
                                 baseColumnNames="preference_id"
                                 constraintName="fk_preference_genre_preference"
                                 referencedTableName="preference"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="preferences-004-preference-track" author="personalization">
        <createTable tableName="preference_track">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="track_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="preference_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex indexName="idx_preference_track_preference_id" tableName="preference_track">
            <column name="preference_id"/>
        </createIndex>
        <addForeignKeyConstraint baseTableName="preference_track"
                                 baseColumnNames="preference_id"
                                 constraintName="fk_preference_track_preference"
                                 referencedTableName="preference"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="preferences-005-preference-playlist" author="personalization">
        <createTable tableName="preference_playlist">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="playlist_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="preference_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex indexName="idx_preference_playlist_preference_id" tableName="preference_playlist">
            <column name="preference_id"/>
        </createIndex>
        <addForeignKeyConstraint baseTableName="preference_playlist"
                                 baseColumnNames="preference_id"
                                 constraintName="fk_preference_playlist_preference"
                                 referencedTableName="preference"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
